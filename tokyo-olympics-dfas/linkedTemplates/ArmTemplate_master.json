{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "tokyo-olympics-dfas"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://tokyoolympicdataas.dfs.core.windows.net/"
		},
		"HttpCoach_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://github.com/asukhavasi/tokyo-olympics-analysisas/raw/refs/heads/main/Coaches.csv"
		},
		"HttpEntreeGender_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://github.com/asukhavasi/tokyo-olympics-analysisas/raw/refs/heads/main/EntriesGender.csv"
		},
		"HttpMedals_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://github.com/asukhavasi/tokyo-olympics-analysisas/raw/refs/heads/main/Medals.csv"
		},
		"Http_Athletes_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://github.com/asukhavasi/tokyo-olympics-analysisas/raw/refs/heads/main/Athletes.csv"
		},
		"Httpteams_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://github.com/asukhavasi/tokyo-olympics-analysisas/raw/refs/heads/main/Teams.csv"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "tokyo-olympics-dfas_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"HttpCoach_properties_typeProperties_url": {
						"value": "[parameters('HttpCoach_properties_typeProperties_url')]"
					},
					"HttpEntreeGender_properties_typeProperties_url": {
						"value": "[parameters('HttpEntreeGender_properties_typeProperties_url')]"
					},
					"HttpMedals_properties_typeProperties_url": {
						"value": "[parameters('HttpMedals_properties_typeProperties_url')]"
					},
					"Http_Athletes_properties_typeProperties_url": {
						"value": "[parameters('Http_Athletes_properties_typeProperties_url')]"
					},
					"Httpteams_properties_typeProperties_url": {
						"value": "[parameters('Httpteams_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}